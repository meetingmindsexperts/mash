RewriteEngine On

# Redirect legacy .html bookmarks to the PHP pages that render header/footer
# via server-side includes. Use 301 so search engines consolidate.
RewriteRule ^index\.html$     /index.php    [R=301,L]
RewriteRule ^register\.html$  /register.php [R=301,L]

# Clean URL: /gallery -> gallery.php
RewriteRule ^gallery/?$       gallery.php   [L]

# Legacy /resource and /resources URLs now point to the renamed gallery page.
RewriteRule ^resources?/?$    /gallery      [R=301,L]
RewriteRule ^resource\.php$   /gallery.php  [R=301,L]

# Serve index.php as the directory default.
DirectoryIndex index.php index.html
